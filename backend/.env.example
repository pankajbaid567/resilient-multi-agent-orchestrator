# Application metadata
APP_NAME=Reliable AI Agent API
APP_ENV=development
APP_DEBUG=false

# API server binding
API_HOST=0.0.0.0
API_PORT=8000

# Comma-separated list of allowed CORS origins (e.g. frontend URLs)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Redis state/checkpoint storage URL
REDIS_URL=redis://redis:6379/0
REDIS_TTL_SECONDS=86400

# Open-source model provider key (required)
# Example provider: Hugging Face Router (OpenAI-compatible API)
OPEN_SOURCE_API_KEY=your_open_source_api_key
OPEN_SOURCE_BASE_URL=https://router.huggingface.co/v1

# Legacy provider keys (optional)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Web search provider key
TAVILY_API_KEY=your_tavily_api_key

# Model selection and fallback chain
PRIMARY_MODEL=meta-llama/Llama-3.1-8B-Instruct
FALLBACK_MODEL=Qwen/Qwen2.5-7B-Instruct
VALIDATION_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# Execution controls
MAX_RETRIES=3
STEP_TIMEOUT=60
MAX_STEPS=15
# 0 means auto-derive from MAX_STEPS.
GRAPH_RECURSION_LIMIT=0

# Embedding model for vector memory retrieval
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
