# -----------------------------
# Core API keys (required)
# -----------------------------
OPEN_SOURCE_API_KEY=your_open_source_api_key
OPEN_SOURCE_BASE_URL=https://openrouter.ai/api/v1
TAVILY_API_KEY=your_tavily_api_key

# Legacy provider keys (optional)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# -----------------------------
# Backend runtime configuration
# -----------------------------
REDIS_URL=redis://redis:6379/0
PRIMARY_MODEL=meta-llama/llama-3.1-8b-instruct:free
FALLBACK_MODEL=qwen/qwen-2.5-7b-instruct:free
VALIDATION_MODEL=qwen/qwen-2.5-7b-instruct:free

MAX_RETRIES=3
STEP_TIMEOUT=60
MAX_STEPS=15
# 0 means auto-derive from MAX_STEPS.
GRAPH_RECURSION_LIMIT=0
PARALLEL_MODE=true
MULTI_AGENT_MODE=true
MAX_CONCURRENT_STEPS=3
CHAOS_MODE=false
LOG_LEVEL=INFO

# -----------------------------
# Optional app metadata
# -----------------------------
APP_NAME=Reliable AI Agent API
APP_ENV=development
APP_DEBUG=false
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional memory and embedding settings
REDIS_TTL_SECONDS=86400
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# -----------------------------
# Frontend runtime configuration
# -----------------------------
VITE_API_URL=http://localhost:8000